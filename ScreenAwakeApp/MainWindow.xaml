<Window x:Class="ScreenAwake.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Awake"
        Width="420" Height="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">

    <Border Margin="14" CornerRadius="20" BorderThickness="1"
            BorderBrush="{StaticResource StrokeBrush}">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{StaticResource BgTop}" Offset="0"/>
                <GradientStop Color="{StaticResource BgBottom}" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid x:Name="TitleBar" Grid.Row="0" Height="46" Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="7" Background="{StaticResource Accent}"/>
                    <TextBlock Text="Screen Awake" Foreground="{StaticResource TextPrimary}"
                               FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button x:Name="MinBtn" Style="{StaticResource CaptionButton}" Content="&#xE921;"
                            Click="MinBtn_Click"/>
                    <Button x:Name="CloseBtn" Style="{StaticResource CaptionButton}" Content="&#xE8BB;"
                            Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="26,6,26,24">

                <!-- Status hero -->
                <Border CornerRadius="16" Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1"
                        Padding="22,20">
                    <StackPanel HorizontalAlignment="Center">
                        <Border x:Name="StateChip" CornerRadius="20" Padding="12,5"
                                Background="#1B2740" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StateDot" Width="9" Height="9" Fill="{StaticResource TextMuted}"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="StateText" Text="Idle" Margin="8,0,0,0"
                                           Foreground="{StaticResource TextMuted}" FontSize="12.5"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="Countdown" Text="00:00" Foreground="{StaticResource TextPrimary}"
                                   FontSize="52" FontWeight="Bold" HorizontalAlignment="Center"
                                   Margin="0,14,0,0"/>
                        <TextBlock x:Name="SubStatus" Text="Ready when you are"
                                   Foreground="{StaticResource TextMuted}" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Duration -->
                <TextBlock Text="KEEP AWAKE FOR" Foreground="{StaticResource TextMuted}"
                           FontSize="11" FontWeight="SemiBold" Margin="4,22,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource Stepper}" Content="&#8722;"
                            Click="MinutesDown_Click"/>
                    <Border Grid.Column="1" Margin="10,0" CornerRadius="10"
                            Background="{StaticResource FieldBrush}" BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1">
                        <Grid>
                            <TextBox x:Name="MinutesBox" Style="{StaticResource NumField}" Text="30"
                                     PreviewTextInput="Numeric_PreviewTextInput" MaxLength="4"/>
                            <TextBlock Text="min" Foreground="{StaticResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                    <Button Grid.Column="2" Style="{StaticResource Stepper}" Content="&#43;"
                            Click="MinutesUp_Click"/>
                </Grid>

                <!-- Idle threshold -->
                <TextBlock Text="ONLY MOVE AFTER I'M IDLE FOR" Foreground="{StaticResource TextMuted}"
                           FontSize="11" FontWeight="SemiBold" Margin="4,18,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource Stepper}" Content="&#8722;"
                            Click="IdleDown_Click"/>
                    <Border Grid.Column="1" Margin="10,0" CornerRadius="10"
                            Background="{StaticResource FieldBrush}" BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1">
                        <Grid>
                            <TextBox x:Name="IdleBox" Style="{StaticResource NumField}" Text="5"
                                     PreviewTextInput="Numeric_PreviewTextInput" MaxLength="3"/>
                            <TextBlock Text="sec" Foreground="{StaticResource TextMuted}" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                    <Button Grid.Column="2" Style="{StaticResource Stepper}" Content="&#43;"
                            Click="IdleUp_Click"/>
                </Grid>

                <!-- Action -->
                <Button x:Name="ActionBtn" Style="{StaticResource ActionButton}" Content="Start"
                        Margin="0,26,0,0" Click="ActionBtn_Click"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>
